# PostgreSQL (coincide con docker-compose.yml)
DATABASE_URL="postgresql://oppastore:oppastore@localhost:5432/oppastore?schema=public"

# Servidor
PORT=4000
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Auth (Sprint 3 — Google OAuth + JWT)
JWT_SECRET=cambia-esto-en-produccion
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Login del panel admin (Sprint 4)
ADMIN_LOGIN_EMAIL=admin@oppastore.pe
ADMIN_LOGIN_PASSWORD=Admin12345
ADMIN_LOGIN_NAME=Administrador OppaStore

# Cloudinary (Sprint 4 — subida de fotos del panel admin, RF43).
# Sin estas variables el panel cae a pegar una URL de imagen manual.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=oppastore
